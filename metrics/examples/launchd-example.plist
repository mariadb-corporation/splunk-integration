<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mariadb.metrics</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/path/to/splunk-integration/scripts/mariadb_metrics_wrapper.sh</string>
    </array>
    
    <key>EnvironmentVariables</key>
    <dict>
        <key>MARIADB_API_KEY</key>
        <string>your-mariadb-api-key</string>
        <key>MARIADB_API_URL</key>
        <string>https://api.skysql.com</string>
        <key>SPLUNK_HEC_TOKEN</key>
        <string>your-splunk-hec-token</string>
        <key>SPLUNK_HEC_URL</key>
        <string>https://inputs.your-instance.splunkcloud.com:8088</string>
        <key>SPLUNK_HEC_VERIFY_SSL</key>
        <string>true</string>
    </dict>
    
    <key>StartInterval</key>
    <integer>60</integer>
    
    <key>StandardOutPath</key>
    <string>/var/log/mariadb_metrics.log</string>
    
    <key>StandardErrorPath</key>
    <string>/var/log/mariadb_metrics.error.log</string>
    
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
